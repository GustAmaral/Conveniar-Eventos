<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DBE2E6">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <include layout="@layout/toolbar_padrao" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/layout_login"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Identifique-se"
                    android:textColor="#0067AB"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_gravity="center"
                    android:layout_marginBottom="24dp"/>

                <EditText
                    android:id="@+id/et_login_cpf"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="CPF (apenas números)"
                    android:inputType="number"
                    android:background="@drawable/bg_edit_text"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/et_login_senha"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Senha"
                    android:inputType="textPassword"
                    android:background="@drawable/bg_edit_text"
                    android:layout_marginBottom="24dp"/>

                <Button
                    android:id="@+id/btn_login"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Entrar"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="#0067AB"
                    app:cornerRadius="10dp"/>

                <TextView
                    android:id="@+id/tv_alternar_cadastro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Não tem uma conta? Cadastre-se aqui"
                    android:textColor="#0067AB"
                    android:layout_gravity="center"
                    android:layout_marginTop="20dp"
                    android:padding="8dp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_cadastro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Criar Conta"
                    android:textColor="#0067AB"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_gravity="center"
                    android:layout_marginBottom="24dp"/>

                <EditText android:id="@+id/et_cad_nome" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Nome Completo *" android:background="@drawable/bg_edit_text" android:layout_marginBottom="12dp" android:inputType="textPersonName"/>
                <EditText android:id="@+id/et_cad_cpf" android:layout_width="match_parent" android:layout_height="50dp" android:hint="CPF (somente números) *" android:background="@drawable/bg_edit_text" android:layout_marginBottom="12dp" android:inputType="number"/>
                <EditText android:id="@+id/et_cad_email" android:layout_width="match_parent" android:layout_height="50dp" android:hint="E-mail *" android:background="@drawable/bg_edit_text" android:layout_marginBottom="12dp" android:inputType="textEmailAddress"/>
                <EditText android:id="@+id/et_cad_email_conf" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Confirme o e-mail *" android:background="@drawable/bg_edit_text" android:inputType="textEmailAddress" android:layout_marginBottom="12dp" />
                <EditText android:id="@+id/et_cad_telefone" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Telefone" android:background="@drawable/bg_edit_text" android:layout_marginBottom="12dp" android:inputType="phone"/>
                <EditText android:id="@+id/et_cad_orgao" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Órgão / Empresa" android:background="@drawable/bg_edit_text" android:layout_marginBottom="12dp" android:inputType="text"/>
                <EditText android:id="@+id/et_cad_cargo" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Cargo" android:background="@drawable/bg_edit_text" android:layout_marginBottom="12dp" android:inputType="text"/>
                <EditText android:id="@+id/et_cad_senha" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Senha (mínimo 6 caracteres) *" android:background="@drawable/bg_edit_text" android:layout_marginBottom="12dp" android:inputType="textPassword"/>
                <EditText android:id="@+id/et_cad_senha_conf" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Confirmar Senha *" android:background="@drawable/bg_edit_text" android:layout_marginBottom="24dp" android:inputType="textPassword"/>

                <Button
                    android:id="@+id/btn_cadastrar"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Finalizar Cadastro"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="#0067AB"
                    app:cornerRadius="10dp"/>

                <TextView
                    android:id="@+id/tv_alternar_login"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Já possui cadastro? Faça o Login"
                    android:textColor="#0067AB"
                    android:layout_gravity="center"
                    android:layout_marginTop="20dp"
                    android:padding="8dp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
