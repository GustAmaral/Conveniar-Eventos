<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="12dp"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_doc_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_doc_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pendente"
            android:textColor="#E65100"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_doc_nome_arquivo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nenhum arquivo selecionado"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        android:singleLine="true"
        android:ellipsize="middle" />

    <Button
        android:id="@+id/btn_selecionar_arquivo"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="Selecionar arquivo"
        android:backgroundTint="#0067AB"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:paddingHorizontal="16dp" />

</LinearLayout>