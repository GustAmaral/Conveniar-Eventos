<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DBE2E6">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <include layout="@layout/toolbar_padrao" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_titulo_inscricao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Inscrição no Curso"
                android:textColor="#0067AB"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <LinearLayout
                android:id="@+id/ll_campos_gestao_juridico"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <EditText
                    android:id="@+id/et_ins_matricula"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Matrícula Funcional"
                    android:background="@android:color/white"
                    android:paddingLeft="12dp"
                    android:layout_marginBottom="12dp"
                    android:inputType="text"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_campos_ti"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nível de experiência em TI:"
                    android:layout_marginBottom="4dp"/>
                <Spinner
                    android:id="@+id/sp_ins_nivel_ti"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@android:color/white"
                    android:entries="@array/niveis_ti"
                    android:layout_marginBottom="12dp"/>
                <EditText
                    android:id="@+id/et_ins_linkedin"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="URL do LinkedIn"
                    android:background="@android:color/white"
                    android:paddingLeft="12dp"
                    android:layout_marginBottom="12dp"
                    android:inputType="textUri"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_campos_comunicacao_gestao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <EditText
                    android:id="@+id/et_ins_area_atuacao"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Área de Atuação principal"
                    android:background="@android:color/white"
                    android:paddingLeft="12dp"
                    android:layout_marginBottom="12dp"
                    android:inputType="text"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_campos_oab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <EditText
                    android:id="@+id/et_ins_oab"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Inscrição OAB (Ex: MG-123456)"
                    android:background="@android:color/white"
                    android:paddingLeft="12dp"
                    android:layout_marginBottom="12dp"
                    android:inputType="text"/>
            </LinearLayout>

            <EditText
                android:id="@+id/et_ins_motivacao"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="Qual sua motivação para realizar este curso? (Opcional)"
                android:background="@android:color/white"
                android:gravity="top|left"
                android:padding="12dp"
                android:layout_marginBottom="24dp"
                android:inputType="textMultiLine"/>

            <Button
                android:id="@+id/btn_confirmar_inscricao"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Confirmar Minha Inscrição"
                android:backgroundTint="#0067AB"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="16sp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>