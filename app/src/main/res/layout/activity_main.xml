<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E0E5E9"
    tools:context=".ui.MainActivity">

    <!-- CABEÇALHO BRANCO -->
    <RelativeLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#FFFFFF"
        android:layout_alignParentTop="true">

        <!-- ===== LOGO CONVENIAR AQUI ===== -->
        <!-- O 'android:src' aponta para a imagem padrão por enquanto.
             Você vai alterar de '@drawable/ic_launcher_foreground' para '@drawable/sua_logo_conveniar' -->
        <ImageView
            android:id="@+id/img_logo_conveniar"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:adjustViewBounds="true"
            android:src="@drawable/ic_launcher_foreground"
            android:contentDescription="Logo Conveniar" />
    </RelativeLayout>

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/txt_titulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/header_layout"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="32dp"
        android:text="Conveniar Eventos"
        android:textColor="#005B9A"
        android:textSize="32sp"
        android:textStyle="bold" />

    <!-- BOTÃO: ACESSAR LISTA -->
    <Button
        android:id="@+id/btn_lista_eventos"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_below="@id/txt_titulo"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="32dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="32dp"
        android:backgroundTint="#0066A5"
        android:text="Acessar lista de eventos"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"
        android:textSize="22sp"
        app:cornerRadius="12dp" />

    <!-- BOTÃO: ÁREA DO INSCRITO -->
    <Button
        android:id="@+id/btn_area_inscrito"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_below="@id/btn_lista_eventos"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="32dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="32dp"
        android:backgroundTint="#0066A5"
        android:text="Área do inscrito"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"
        android:textSize="22sp"
        app:cornerRadius="12dp" />

    <!-- ===== LOGO CIENTEC AQUI ===== -->
    <!-- Assim como no topo, altere o 'android:src' para '@drawable/sua_logo_cientec' -->
    <ImageView
        android:id="@+id/img_logo_cientec"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:adjustViewBounds="true"
        android:src="@drawable/ic_launcher_foreground"
        android:contentDescription="Logo Cientec" />

</RelativeLayout>