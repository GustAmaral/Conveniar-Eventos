<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema Base do Aplicativo para Modo Claro (Day) -->
    <style name="Theme.ConveniarEventos" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Cor primária de elementos estruturais e botões -->
        <item name="android:statusBarColor">#DBE2E6</item>
        <item name="android:fontFamily">@font/instrument_sans_ttf</item>
        <item name="fontFamily">@font/instrument_sans_ttf</item>
        <item name="colorPrimary">#0067AB</item>
        <item name="colorPrimaryDark">#004B7D</item>
        <item name="colorAccent">#0067AB</item>
    </style>

    <style name="Theme.ConveniarEventos.Splash"
        parent="Theme.SplashScreen">

        <item name="windowSplashScreenBackground">#DBE2E6</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/conveniar_icone_peq</item>
        <item name="postSplashScreenTheme">
            @style/Theme.ConveniarEventos
        </item>

    </style>
</resources>